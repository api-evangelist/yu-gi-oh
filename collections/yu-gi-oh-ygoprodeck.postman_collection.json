          "name": "YGOPRODeck List Archetypes",
          "request": {
            "name": "YGOPRODeck List Archetypes",
            "description": {
              "content": "Return every recognised Yu-Gi-Oh! archetype name. Useful to populate archetype pickers\nand to validate the `archetype` parameter on `/cardinfo.php`.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "archetypes.php"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
